<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Applied only for the macOS SDK via CODE_SIGN_ENTITLEMENTS overrides
	     in project.yml, so the tvOS/iOS entitlements stay byte-identical
	     (PRD-4 §1). App Sandbox is mandatory for the Mac App Store; the
	     network client is for Game Center; KVS carries the same streak /
	     history sync as every other platform. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.developer.game-center</key>
	<true/>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
	<!-- Cloud library (PRD-8): private CloudKit database for CKSyncEngine. The
	     App Sandbox + network.client entitlements above already permit it. -->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.couchsuite.nine</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>
	<!-- CloudKit delivers silent change pushes, so App Store Connect rejects
	     any target that declares icloud-services without aps-environment
	     (upload error 90575). App Store distribution uses the production APS. -->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
