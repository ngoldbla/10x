default_platform(:ios)

# Reuse the existing App Store Connect API key for match + pilot.
# Supports either a .p8 file path (ASC_KEY_PATH) or base64 content (ASC_KEY_P8),
# mirroring scripts/testflight.sh so local and CI auth stay identical.
def asc_api_key
  key_id    = ENV["ASC_KEY_ID"].to_s
  issuer_id = ENV["ASC_ISSUER_ID"].to_s
  UI.user_error!("Set ASC_KEY_ID and ASC_ISSUER_ID (did you `source signing.env`?)") if key_id.empty? || issuer_id.empty?
  if (path = ENV["ASC_KEY_PATH"]) && !path.empty?
    app_store_connect_api_key(key_id: key_id, issuer_id: issuer_id, key_filepath: path)
  elsif (content = ENV["ASC_KEY_P8"]) && !content.empty?
    app_store_connect_api_key(
      key_id: key_id, issuer_id: issuer_id,
      key_content: content, is_key_content_base64: true
    )
  else
    UI.user_error!("Set ASC_KEY_PATH (a .p8 file) or ASC_KEY_P8 (base64 of the .p8)")
  end
end

# The five Couch Suite apps: folder => Xcode scheme + bundle identifier.
# All five ship for tvOS; apps flagged `ios: true` are universal and also ship
# an iOS (iPhone/iPad) build from the same target. Match profile naming:
#   tvOS: "match AppStore <bundle> tvos"   ·   iOS: "match AppStore <bundle>"
APPS = {
  "rabbit-ears" => { scheme: "RabbitEars", bundle: "com.couchsuite.rabbitears" },
  "darkroom"    => { scheme: "Darkroom",   bundle: "com.couchsuite.darkroom" },
  "nine"        => { scheme: "Nine",       bundle: "com.couchsuite.nine", ios: true },
  "blockhead"   => { scheme: "Blockhead",  bundle: "com.couchsuite.blockhead" },
  "cartridge"   => { scheme: "Cartridge",  bundle: "com.couchsuite.cartridge" }
}.freeze

platform :ios do
  desc "Build one Couch Suite app and upload to TestFlight (app:<folder>, platform:tvos|ios, upload:false = dry run)"
  lane :beta do |options|
    app_key = options.fetch(:app, "rabbit-ears")
    cfg = APPS[app_key] || UI.user_error!("Unknown app '#{app_key}'. One of: #{APPS.keys.join(', ')}")
    plat = options.fetch(:platform, "tvos").to_s
    UI.user_error!("platform must be 'tvos' or 'ios'") unless %w[tvos ios].include?(plat)
    UI.user_error!("#{app_key} has no iOS build (only: #{APPS.select { |_, c| c[:ios] }.keys.join(', ')})") if plat == "ios" && !cfg[:ios]
    do_upload = options.fetch(:upload, true)
    app_id  = cfg[:bundle]
    scheme  = cfg[:scheme]
    folder  = File.expand_path("../#{app_key}", __dir__)
    profile = plat == "ios" ? "match AppStore #{app_id}" : "match AppStore #{app_id} tvos"
    destination = plat == "ios" ? "generic/platform=iOS" : "generic/platform=tvOS"
    ipa_name = plat == "ios" ? "#{scheme}-iOS.ipa" : "#{scheme}.ipa"
    # Build number derived from git history — monotonic, never committed back.
    # iOS and tvOS build trains are separate in App Store Connect, so the same
    # number on both platforms is fine.
    build = sh("git", "-C", File.expand_path("..", __dir__), "rev-list", "--count", "HEAD").strip

    key = asc_api_key
    setup_ci # temp keychain on CI; no-op locally

    # readonly: fetch the existing cert + profile from the match repo, never mint.
    match(type: "appstore", platform: plat, app_identifier: app_id, api_key: key, readonly: true)

    Dir.chdir(folder) { sh("xcodegen", "generate") }

    gym(
      project: "#{folder}/#{scheme}.xcodeproj",
      scheme: scheme,
      destination: destination,
      export_method: "app-store",
      output_directory: "#{folder}/dist",
      output_name: ipa_name,
      xcargs: "CURRENT_PROJECT_VERSION=#{build}",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { app_id => profile }
      }
    )

    if do_upload
      pilot(api_key: key, app_identifier: app_id, skip_waiting_for_build_processing: true)
      UI.success("#{app_key} (#{plat}) build #{build} uploaded to TestFlight")
    else
      UI.success("#{app_key} (#{plat}) build #{build} exported (dry run): #{app_key}/dist/#{ipa_name}")
    end
  end

  desc "Ship every platform build for one app: tvOS, plus iOS when universal (app:<folder>, upload:false = dry run)"
  lane :beta_app do |options|
    app_key = options.fetch(:app)
    cfg = APPS[app_key] || UI.user_error!("Unknown app '#{app_key}'. One of: #{APPS.keys.join(', ')}")
    beta(options.merge(platform: "tvos"))
    beta(options.merge(platform: "ios")) if cfg[:ios]
  end

  desc "Build + upload ALL Couch Suite builds to TestFlight: tvOS for all five, plus iOS for universal apps (upload:false = dry run)"
  lane :beta_all do |options|
    APPS.each_key { |app_key| beta_app(options.merge(app: app_key)) }
  end
end
