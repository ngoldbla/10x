# Xcode
xcuserdata/
*.xcscmblueprint
DerivedData/
.derivedData/
build/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.xccheckout
*.xcworkspace
!default.xcworkspace

# XcodeGen generates each app's .xcodeproj, Info.plist, and entitlements from
# its project.yml — none of these are committed.
*.xcodeproj/
*/Info.plist
*/WidgetsInfo.plist
*/*.entitlements
# …except Nine's iOS entitlements: xcodegen emits one entitlements file per
# target, and the iOS app needs a second (app group) applied per-SDK, so this
# one is checked in (PRD-3).
!nine/Nine-iOS.entitlements

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved

# Build / TestFlight output (scripts/testflight.sh)
*/build/
*/dist/

# Local signing configuration (team ID, ASC API key) — never committed.
signing.env

# macOS
.DS_Store
*.swp
*~

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/README.md
fastlane/screenshots/**/*.png
fastlane/test_output
*.mobileprovision
*.p12
*.p8
*/build-tvos/
