.build/
*.xcodeproj/
DerivedData/
# XcodeGen generates each app's Info.plist from its project.yml `properties`.
*/Info.plist
# xcodebuild -derivedDataPath output used by the run/verify pipeline.
*/build/
# XcodeGen also generates each app's entitlements from project.yml.
*/*.entitlements
# TestFlight archive/export output (scripts/testflight.sh).
*/dist/
# Local signing configuration (team ID, ASC API key) — never committed.
signing.env
